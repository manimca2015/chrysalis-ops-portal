rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permissive rules for management portal collections to allow initialization and prototype testing
    // In a production environment, these would be restricted to authenticated staff with specific roles
    
    match /mgmt_staff/{userId} {
      allow read, write: if true;
    }

    match /mgmt_suppliers/{supplierId} {
      allow read, write: if true;
    }

    match /mgmt_projects/{projectId} {
      allow read, write: if true;
      match /activity/{activityId} {
        allow read, write: if true;
      }
    }

    match /mgmt_enquiries/{id} {
      allow read, write: if true;
    }

    match /mgmt_questionnaire_templates/{id} {
      allow read, write: if true;
    }

    match /mgmt_task_templates/{id} {
      allow read, write: if true;
    }

    match /mgmt_tasks/{id} {
      allow read, write: if true;
    }

    match /mgmt_audit_log/{id} {
      allow read, write: if true;
    }

    match /mgmt_costing_sets/{id} {
      allow read, write: if true;
    }

    match /mgmt_costing_items/{id} {
      allow read, write: if true;
    }

    match /mgmt_payment_plans/{id} {
      allow read, write: if true;
    }

    match /mgmt_documents/{id} {
      allow read, write: if true;
    }

    match /mgmt_supplier_bills/{id} {
      allow read, write: if true;
    }

    match /mgmt_supplier_payments/{id} {
      allow read, write: if true;
    }

    // Production users collection - required for the login and seeding process
    match /users/{userId} {
      allow read, write: if true;
    }
  }
}