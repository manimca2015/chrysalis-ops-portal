rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Production users collection - allow users to read their own profile for status verification
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
    }

    // Management portal staff profiles
    match /mgmt_staff/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null;
    }

    // Projects and their sub-activities
    match /mgmt_projects/{projectId} {
      allow read, write: if request.auth != null;
      
      match /activity/{activityId} {
        allow read, write: if request.auth != null;
      }
    }

    // Other management collections
    match /mgmt_enquiries/{enquiryId} {
      allow read, write: if request.auth != null;
    }
    
    match /mgmt_tasks/{taskId} {
      allow read, write: if request.auth != null;
    }
    
    match /mgmt_costing_sets/{setId} {
      allow read, write: if request.auth != null;
    }
    
    match /mgmt_costing_items/{itemId} {
      allow read, write: if request.auth != null;
    }
    
    match /mgmt_audit_log/{logId} {
      allow read, create: if request.auth != null;
    }

    match /mgmt_payment_plans/{planId} {
      allow read, write: if request.auth != null;
    }
    
    match /mgmt_documents/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}