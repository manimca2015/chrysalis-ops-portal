rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Production users collection - read-only for authentication status
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
    }

    // Management portal staff profiles
    // Allow users to manage their own profile, or admins to manage all profiles
    match /mgmt_staff/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Questionnaire and Task Templates
    match /mgmt_questionnaire_templates/{tplId} {
      allow read, write: if request.auth != null;
    }
    
    match /mgmt_task_templates/{tplId} {
      allow read, write: if request.auth != null;
    }

    // Enquiries and Lead Ingestion
    match /mgmt_enquiries/{enquiryId} {
      allow read, write: if request.auth != null;
    }

    // Suppliers Database
    match /mgmt_suppliers/{supplierId} {
      allow read, write: if request.auth != null;
    }

    // Projects and their sub-activity logs
    match /mgmt_projects/{projectId} {
      allow read, write: if request.auth != null;
      
      match /activity/{activityId} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Project Tasks
    match /mgmt_tasks/{taskId} {
      allow read, write: if request.auth != null;
    }

    // Audit and System Logs
    match /mgmt_audit_log/{logId} {
      allow read, create: if request.auth != null;
    }

    // Costing Engine
    match /mgmt_costing_sets/{setId} {
      allow read, write: if request.auth != null;
    }
    
    match /mgmt_costing_items/{itemId} {
      allow read, write: if request.auth != null;
    }

    // Supplier Bills and Payments
    match /mgmt_supplier_bills/{billId} {
      allow read, write: if request.auth != null;
    }

    match /mgmt_supplier_payments/{paymentId} {
      allow read, write: if request.auth != null;
    }

    // Documents and Payment Plans
    match /mgmt_payment_plans/{planId} {
      allow read, write: if request.auth != null;
    }
    
    match /mgmt_documents/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}